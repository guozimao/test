maShort    = request.security(syminfo.tickerid, "D", ta.sma(close, maShortLen))
maMid      = request.security(syminfo.tickerid, "D", ta.sma(close, maMidLen))
maLong     = request.security(syminfo.tickerid, "D", ta.sma(close, maLongLen))

// 成交量
vol = volume

// 均量
vol5  = ta.sma(vol, 5)
vol10 = ta.sma(vol, 10)
vol20 = ta.sma(vol, 20)

// ATR
atrValue = ta.atr(atrLength)

// 20日新高
highestHigh = ta.highest(high, 20)
// 价格10日新低
lowestLow = ta.lowest(low, 10)

devFromMA = (dailyClose - maShort) / maShort * 100
dailyPct  = (dailyClose - dailyClose[1]) / dailyClose[1] * 100

// 偏离5日EMA（%）
devFromMA5 = (dailyClose - maFast) / maFast * 100

// 偏离50日EMA（%）
devFromMA50 = (dailyClose - maMid) / maMid * 100

// =====================
// 🧠 市场状态
// =====================
bull = dailyClose > maLong
bear = dailyClose < maLong
// 状态调节
scoreMain = bull ? scoreMainBase : scoreMainBase - 0.5
scoreAdd  = bull ? scoreAddBase  : scoreAddBase - 0.3

// =====================
// 🎯 评分系统
// =====================
score = 0.0
// RSI（轻权重）
score += (rsiVal <= rsiOS ? 1.0 : 0.0)
score += (rsiVal <= 25 ? 0.5 : 0.0)
// 偏离MA
score += (devFromMA <= -devPct ? 1.0 : 0.0)
score += (devFromMA <= -8 ? 0.5 : 0.0)
// 短期恐慌
score += (dailyPct <= -2 ? 1.0 : 0.0)
// 熊市加权（更容易出现机会）
score += bear ? 0.3 : 0.0

// =====================
// 🎯 信号
// =====================
condMain = score >= scoreMain
condAdd  = score >= scoreAdd and score < scoreMain

// =====================
