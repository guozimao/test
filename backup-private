maShort    = timeframe.isweekly ? request.security(syminfo.tickerid, "W", ta.sma(close, maShortWeekLen)) : request.security(syminfo.tickerid, "D", ta.sma(close, maShortLen))
maMid      = timeframe.isweekly ? request.security(syminfo.tickerid, "W", ta.sma(close, maMidWeekLen)) : request.security(syminfo.tickerid, "D", ta.sma(close, maMidLen))
maLong     = request.security(syminfo.tickerid, tf, ta.sma(close, maLongLen))

// ATR
atrValue = ta.atr(atrLength)

devFromMA = (dailyClose - maShort) / maShort * 100
dailyPct  = (dailyClose - dailyClose[1]) / dailyClose[1] * 100

// 偏离5日EMA（%）
devFromMA5 = (dailyClose - maFast) / maFast * 100

// 偏离50日EMA（%）
devFromMA50 = (dailyClose - maMid) / maMid * 100

// =====================
